HTTP_LISTEN='localhost:8001'
HTTP_READ_TIMEOUT='60s'
HTTP_WRITE_TIMEOUT='0s'  # 0 = no timeout; required for long-running LLM responses
HTTP_IDLE_TIMEOUT='60s'
HTTP_GRACEFUL_SHUTDOWN='30s'
HTTP_DEBUG='false'

OLLAMA_SERVER_ADDRESS='http://127.0.0.1:11434'
OLLAMA_EMBEDDING_MODEL='all-minilm:33m'
OLLAMA_GENERATIVE_MODEL='qwen3-coder:480b-cloud'

PG_HOST='localhost:5432'
PG_USER='postgres'
PG_PASSWORD='postgres'
PG_USER_ADMIN='postgres'
PG_PASSWORD_ADMIN='postgres'
PG_DATABASE='postgres'

LOG_LEVEL='debug'

JOB_QUEUE_POLL_INTERVAL='5s'
JOB_QUEUE_TIMEOUT='15s'
JOB_QUEUE_WORKERS_COUNT=2

SPLITTER_CHUNK_SIZE=200
SPLITTER_CHUNK_OVERLAP=20